# Copy this file to .env and fill in your values
# cp .env.example .env

# REQUIRED: Change this to a long random string before deploying
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-string

# OPTIONAL: Restrict CORS to specific origins (comma-separated)
# Leave empty to allow same-origin only (recommended for home servers)
# CORS_ORIGINS=http://192.168.1.100:3000,http://myserver.local:3000

# OPTIONAL: Change the port (default: 3000)
# PORT=3000
