# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: Change this to a long random string before deploying
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-string

# ── Default Admin Account ─────────────────────────────────────────────────────
# These only take effect the FIRST time the container starts (when there are no users).
# After that, change credentials via the Settings page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@ledgerengine.local
ADMIN_NAME=Administrator

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave empty for same-origin only (recommended).
# CORS_ORIGINS=http://192.168.1.100:3000,http://myserver.local:3000

# ── Server (optional) ─────────────────────────────────────────────────────────
# PORT=3000
